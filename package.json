{
  "name": "mymarkdown",
  "version": "0.1.0",
  "private": true,
  "description": "myMarkDown desktop app (Git-only backend)",
  "main": "dist/main/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist/main/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "test:main": "npm run build:main && node --test tests/main/*.test.js",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@toast-ui/editor": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vite": "^8.0.3",
    "wait-on": "^8.0.0"
  }
}
